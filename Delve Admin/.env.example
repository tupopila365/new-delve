# Leave empty to use Vite proxy to Django (http://127.0.0.1:8000) in local dev.
VITE_API_URL=

# Use built-in mock data (no backend required). Set false for real API / Heroku beta.
VITE_USE_MOCKS=true

# For real transport verification data: set VITE_USE_MOCKS=false, run Django, then:
#   python manage.py seed_delve
# Log in as demo_admin / demo12345 — Verifications shows Namibia Wheels (transport_mgr).

# Delve Admin runs on port 5174 — included in backend CORS defaults when using real API.

# Main traveller app URL for "View public profile" links
# Local: http://localhost:5173
# Heroku: https://delve-app-xxxx.herokuapp.com
VITE_PUBLIC_APP_URL=http://localhost:5173
