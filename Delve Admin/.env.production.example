# Set these as Heroku Config Vars on the admin app BEFORE the first deploy.
# Vite bakes them into the bundle at build time (heroku-postbuild).

VITE_USE_MOCKS=false
VITE_API_URL=https://delve-api-xxxx.herokuapp.com
VITE_PUBLIC_APP_URL=https://delve-app-xxxx.herokuapp.com

# After deploy, create staff on the API app:
#   heroku run -a delve-api-xxxx python manage.py ensure_platform_admin --email you@example.com --password 'SecurePass123!'
# Then sign in to Delve Admin with that email. API must have CLOUDINARY_URL for verification document review.
