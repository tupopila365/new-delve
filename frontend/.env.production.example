# Set these as Heroku Config Vars on the traveller app BEFORE the first deploy.
# Vite bakes them into the bundle at build time (heroku-postbuild).

VITE_USE_MOCKS=false
VITE_API_URL=https://delve-api-xxxx.herokuapp.com
VITE_ADMIN_APP_URL=https://delve-admin-xxxx.herokuapp.com

# Backend (Heroku API app) — required for voice notes, photos, and group media:
# CLOUDINARY_URL=cloudinary://...
# DJANGO_ALLOWED_HOSTS=delve-api-xxxx.herokuapp.com
# CORS_ALLOWED_ORIGINS=https://your-frontend.herokuapp.com
# CSRF_TRUSTED_ORIGINS=https://your-frontend.herokuapp.com
