# Local overrides: copy to .env.development.local or .env.local (do not commit secrets).

# Use real Django API (required for beta / Heroku).
VITE_USE_MOCKS=false

# Django API origin. Leave empty only when the API is same-origin (not typical on Heroku).
# Local: http://127.0.0.1:8000
# Heroku: https://delve-api-xxxx.herokuapp.com
VITE_API_URL=http://127.0.0.1:8000

# Delve Admin console (staff handoff from /admin).
# Local: http://localhost:5174
# Heroku: https://delve-admin-xxxx.herokuapp.com
VITE_ADMIN_APP_URL=http://localhost:5174
