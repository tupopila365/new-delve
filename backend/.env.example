# Copy to .env for local overrides (not used by Heroku — set Config Vars there).

DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Leave unset locally to use SQLite. Heroku sets this via the Postgres addon.
# DATABASE_URL=postgres://user:pass@host:5432/dbname

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://localhost:5174

# Must be the live traveller app URL on Heroku (verification + password-reset links).
FRONTEND_URL=http://localhost:5173

# --- Email (Step 2) ---
# Local: console prints messages in the runserver terminal.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@delve.local

# Heroku / beta — use real SMTP (example: Brevo):
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# DEFAULT_FROM_EMAIL=Delve <your-verified-sender@email.com>
# EMAIL_HOST=smtp-relay.brevo.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=true
# EMAIL_HOST_USER=your-brevo-login@email.com
# EMAIL_HOST_PASSWORD=your-brevo-smtp-key
#
# SendGrid example:
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_USE_TLS=true
# EMAIL_HOST_USER=apikey
# EMAIL_HOST_PASSWORD=SG.your-sendgrid-api-key
#
# Test on Heroku after deploy:
#   heroku run -a delve-api python manage.py send_test_email you@example.com

EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# Optional: Cloudinary for media on Heroku (required for durable uploads).
# Format: cloudinary://api_key:api_secret@cloud_name
# CLOUDINARY_URL=
